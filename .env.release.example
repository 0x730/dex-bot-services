# Copy this file to `.env.release.local` and fill in real values.
# `.env.release.local` is intentionally gitignored.

# GitHub authentication. Prefer a fine-scoped token that can create/push this repo.
# Do not commit real tokens.
GITHUB_PAT=replace_with_github_token

# Public GitHub repository, for this release target.
GITHUB_REPO=0x730/dex-bot-services
GITHUB_REPO_VISIBILITY=public

# Release metadata. Use auto to publish the next patch from GitHub tags/releases.
RELEASE_VERSION=auto
RELEASE_DRY_RUN_VERSION=0.0.1
PUBLIC_RELEASE_DIR=/tmp/dex-bot-services-public

# Set true only when this public repo is a generated snapshot mirror and replacing
# remote main is intended. Fetches first, then uses --force-with-lease.
RELEASE_REPLACE_MAIN=false

# Required acknowledgement. Set to true only after rotating historical secrets.
RELEASE_SECRETS_ROTATED=false

# Commit identity used inside the generated public snapshot.
GIT_AUTHOR_NAME=Daniel Vladescu
GIT_AUTHOR_EMAIL=daniel.vladescu@gmail.com
