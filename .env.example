# Copy to a local .env file and replace placeholders.
# Never commit real private keys or RPC tokens.

GAS_BUFFER_PERCENT=10
MAX_GAS_ETHEREUM=1000000
HOST=127.0.0.1
BOT_API_TOKEN=
BOT_LOG_FORMAT=text
BOT_NONCE_LOCK_MODE=process
BOT_NONCE_LOCK_DIR=/tmp/dex-bot-services-nonce
BOT_NONCE_LOCK_STALE_MS=30000
BOT_NONCE_LOCK_WAIT_MS=10000

UNI_V2_PORT=3000
UNI_V2_RPC_URL_ETHEREUM=https://example.invalid/ethereum-rpc
